# Production build args for the ROOT docker-compose.yml (web image).
#
# These vars are consumed by `docker compose build web` as BUILD ARGS.
# They are baked into the JS bundle at build time, so after changing
# any value you MUST rebuild the web image:
#
#   export $(grep -v '^#' .env.production | xargs)
#   docker compose build web
#   docker compose up -d web
#
# Source: never commit real values. This file is gitignored.

# ─── Backend API (used by SSR + client) ─────────────────────
NEXT_PUBLIC_API_BASE=https://enpii.enpiistudio.com/api/v1

# ─── Google OAuth (client ID only — secret stays on backend) ─
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<from-google-cloud-console>

# ─── Reverb WebSocket endpoint ───────────────────────────────
# Browser opens WS to wss://<host>:<port>. NPM terminates TLS
# and forwards /app → reverb:8080 over the web-network.
NEXT_PUBLIC_REVERB_SCHEME=wss
NEXT_PUBLIC_REVERB_HOST=enpii.enpiistudio.com
NEXT_PUBLIC_REVERB_PORT=443
# MUST equal REVERB_APP_KEY in backend/.env (NOT the SECRET).
NEXT_PUBLIC_REVERB_APP_KEY=<openssl-rand-hex-16>

# ─── Backend Postgres password (read by docker-compose env) ──
DB_PASSWORD=<strong-password>
