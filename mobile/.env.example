# -----------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit it.
#
# Run via: ./scripts/run_dev.sh
# -----------------------------------------------------------------------------

# Web OAuth Client ID (type 3) from GCP.
# Used as `serverClientId` for google_sign_in (mobile) and as `client_id`
# by the backend when exchanging the server_auth_code.
# This ID is technically public (it's bundled into the APK), but treat
# rotation cadence the same as any other credential.
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# DO NOT put GOOGLE_CLIENT_SECRET here.
#
# The OAuth client secret is a SERVER-SIDE credential. It belongs only on
# the backend that exchanges `server_auth_code` for tokens. Including it
# in a mobile app makes it trivially extractable from the APK and is an
# OAuth client misuse violation per Google's API Services User Data Policy.
# -----------------------------------------------------------------------------
