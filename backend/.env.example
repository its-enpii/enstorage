APP_NAME=EnStorage
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=enstorage
DB_USERNAME=enstorage
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Laravel Reverb (WebSocket server, port 8083 di Docker)
REVERB_APP_ID=enstorage
REVERB_APP_KEY=enstorage-reverb-key
REVERB_APP_SECRET=change-me-to-random-32-byte-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8083
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8083

# Frontend pakai NEXT_PUBLIC_REVERB_* (web) / --dart-define (mobile)
# untuk connect ke WS server. Override per-environment di .env.
REVERB_PUBLIC_HOST=localhost
REVERB_PUBLIC_PORT=8083
REVERB_PUBLIC_SCHEME=ws

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/google-accounts/oauth/callback

# Android OAuth client (Google Cloud Console → Application type: Android).
# Package: com.enpiistudio.enstorage, SHA-1 dari: cd mobile/android && ./gradlew signingReport
# Kalau kosong, fallback ke GOOGLE_CLIENT_ID (web client — butuh HTTPS redirect_uri).
GOOGLE_CLIENT_ID_MOBILE=
GOOGLE_CLIENT_SECRET_MOBILE=
GOOGLE_REDIRECT_URI_MOBILE=enstorage://oauth-callback

UPLOAD_MAX_FILE_SIZE=1024
UPLOAD_MAX_FILES_PER_REQUEST=10

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@enstorage.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
