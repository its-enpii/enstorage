# Production backend env — COPY to backend/.env on VPS, then fill in.
#
# `backend/.env` is gitignored. This template lives in git so the
# format is reviewable. NEVER put real secrets here.
#
# Generate the two Reverb keys on the VPS with:
#   openssl rand -hex 16    # public (also goes to web NEXT_PUBLIC_REVERB_APP_KEY)
#   openssl rand -hex 32    # private (server only)

# ─── App ─────────────────────────────────────────────────────
APP_NAME=EnStorage
APP_ENV=production
APP_KEY=<base64:...>          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://enpii.enpiistudio.com

# ─── Database ────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=enstorage
DB_USERNAME=enstorage
DB_PASSWORD=<strong-password>

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Broadcasting (Reverb WebSocket) ─────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=enstorage
REVERB_APP_KEY=<openssl-rand-hex-16>
REVERB_APP_SECRET=<openssl-rand-hex-32>
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ─── Google / Firebase / Misc ────────────────────────────────
# Fill in from your actual credentials
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://enpii.enpiistudio.com/auth/google/callback

FIREBASE_CREDENTIALS=/var/www/html/storage/app/firebase-service-account.json

# Frontend (used for CORS + asset URLs)
FRONTEND_URL=https://enpii.enpiistudio.com
SANCTUM_STATEFUL_DOMAINS=enpii.enpiistudio.com
SESSION_DOMAIN=.enpii.enpiistudio.com
